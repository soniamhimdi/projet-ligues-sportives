generator client {
provider = "prisma-client"
output = "../src/generated/prisma"
}
datasource db {
provider = "postgresql"
}

enum Role {
  PLAYER
  ORGANIZER
  ADMIN
}

enum Level {
  BEGINNER
  INTERMEDIATE
  ADVANCED
}

enum RequestStatus {
  PENDING
  ACCEPTED
  REJECTED
}

enum PaymentStatus {
  NOT_REQUIRED
  PENDING
  PAID
}

model User {
  id            String   @id @default(cuid())
  clerkId       String   @unique
  email         String   @unique
  fullName      String
  role          Role     @default(PLAYER)
  onboarded     Boolean  @default(false)

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  playerProfile PlayerProfile?

  tournaments   Tournament[] @relation("OrganizerTournaments")

  teams         Team[] @relation("TeamMembers")

  joinRequests  JoinRequest[]
}

model PlayerProfile {
  id             String @id @default(cuid())

  userId         String @unique

  city           String

  favoriteSport  String

  level          Level @default(BEGINNER)

  position       String?

  user           User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Tournament {
  id            String   @id @default(cuid())

  name          String

  sport         String

  city          String

  startDate     DateTime

  entryFee      Int @default(0)

  currency      String @default("CAD")

  organizerId   String

  createdAt     DateTime @default(now())

  updatedAt     DateTime @updatedAt

  organizer     User @relation("OrganizerTournaments", fields: [organizerId], references: [id])

  teams         Team[]

  @@index([sport, city])
}

model Team {
  id               String   @id @default(cuid())

  name             String

  tournamentId     String

  maxCapacity      Int @default(15)

  createdAt        DateTime @default(now())

  tournament       Tournament @relation(fields: [tournamentId], references: [id], onDelete: Cascade)

  members          User[] @relation("TeamMembers")

  joinRequests     JoinRequest[]

  matchesAsTeamA   Match[] @relation("TeamA")

  matchesAsTeamB   Match[] @relation("TeamB")
}

model JoinRequest {
  id                String @id @default(cuid())

  playerId          String

  teamId            String

  status            RequestStatus @default(PENDING)

  message           String?

  paymentStatus     PaymentStatus @default(NOT_REQUIRED)

  stripeSessionId   String?

  paidAt            DateTime?

  createdAt         DateTime @default(now())

  updatedAt         DateTime @updatedAt

  player            User @relation(fields: [playerId], references: [id], onDelete: Cascade)

  team              Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([playerId, teamId])

  @@index([status])

  @@index([paymentStatus])
}

model Match {
  id            String @id @default(cuid())

  teamAId       String

  teamBId       String

  date          DateTime

  location      String

  scoreA        Int?

  scoreB        Int?

  createdAt     DateTime @default(now())

  teamA         Team @relation("TeamA", fields: [teamAId], references: [id])

  teamB         Team @relation("TeamB", fields: [teamBId], references: [id])
}
model Product {
id String @id @default(cuid()) // Identifiant unique auto-generer
name String // Nom du produit
description String? // Description optionnelle (? =nullable)
price Decimal // Prix du produit (type Decimal pour la précision)
createdAt DateTime @default(now()) // Date de création automatique
updatedAt DateTime @updatedAt // Date de mise à jour automatique
cartItems CartItem[] // Relation : un produit peut être dans plusieurs paniers
}
 
// Modle Cart : représente un panier d’achat
model Cart {
id String @id @default(cuid()) // Identifiant unique auto-generer
userId String // Identifiant de l’utilisateur propritaire
createdAt DateTime @default(now()) // Date de création automatique
updatedAt DateTime @updatedAt // Date de mise à jour automatique
items CartItem[] // Relation : un panier contient plusieurs articles
}
 
// Modele CartItem : représente un article dans un panier (table de liaison)
model CartItem {
id String @id @default(cuid()) // Identifiant unique auto-generer
quantity Int // Quantité de ce produit dans le panier
cartId String // Clé étrangère vers Cart
cart Cart @relation(fields: [cartId], references: [id]) // Relation vers Cart
productId String // Clé étrangère vers Product
product Product @relation(fields: [productId], references: [id]) // Relation vers Product
}