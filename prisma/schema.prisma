// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`


generator client {
provider = "prisma-client"
output = "../app/generated/prisma"
}
datasource db {
provider = "postgresql"
}
model Product {
id String @id @default(cuid()) // Identifiant unique auto-generer
name String // Nom du produit
description String? // Description optionnelle (? =nullable)
price Decimal // Prix du produit (type Decimal pour la précision)
createdAt DateTime @default(now()) // Date de création automatique
updatedAt DateTime @updatedAt // Date de mise à jour automatique
cartItems CartItem[] // Relation : un produit peut être dans plusieurs paniers
}
 
// Modle Cart : représente un panier d’achat
model Cart {
id String @id @default(cuid()) // Identifiant unique auto-generer
userId String // Identifiant de l’utilisateur propritaire
createdAt DateTime @default(now()) // Date de création automatique
updatedAt DateTime @updatedAt // Date de mise à jour automatique
items CartItem[] // Relation : un panier contient plusieurs articles
}
 
// Modele CartItem : représente un article dans un panier (table de liaison)
model CartItem {
id String @id @default(cuid()) // Identifiant unique auto-generer
quantity Int // Quantité de ce produit dans le panier
cartId String // Clé étrangère vers Cart
cart Cart @relation(fields: [cartId], references: [id]) // Relation vers Cart
productId String // Clé étrangère vers Product
product Product @relation(fields: [productId], references: [id]) // Relation vers Product
}
